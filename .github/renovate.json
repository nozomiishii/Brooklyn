{
  "extends": ["github>nozomiishii/renovate"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.github/workflows/release\\.yaml$/"
      ],
      "matchStrings": ["npx --yes release-please@(?<currentValue>\\S+)"],
      "depNameTemplate": "release-please",
      "datasourceTemplate": "npm"
    }
  ]
}
